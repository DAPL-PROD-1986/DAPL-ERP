 "font_size": 14,
 "html": "<style>\n    .title {\n        text-align: center;\n        font-size: 22px;\n        font-weight: bold;\n    }\n\n    .subtitle {\n        text-align: center;\n        font-size: 18px;\n        font-weight: bold;\n        margin-bottom: 15px;\n    }\n\n    table {\n        width:100%;\n        border-collapse: collapse;\n        margin-top:10px;\n        font-size:11px;\n    }\n\n    th, td {\n        border:1px solid #000;\n        padding:5px;\n        text-align:left;\n    }\n\n    th{\n        background:#f2f2f2;\n    }\n\n    .section{\n        margin-top:20px;\n        font-size:16px;\n        font-weight:bold;\n        text-align:center;\n        background:#d9edf7;\n        padding:6px;\n        border:1px solid #000;\n    }\n\n    .info td{\n        border:none;\n        padding:3px;\n    }\n    \n    .report-card{\n    border:1px solid #bfbfbf;\n    border-radius:8px;\n    overflow:hidden;\n    margin-top:18px;\n}\n\n.card-header{\n    padding:8px;\n    font-size:16px;\n    font-weight:bold;\n    text-align:center;\n    border-bottom:1px solid #cfcfcf;\n}\n\n.yesterday-header{\n    background:#FFF8D6;      /* Light Yellow */\n    color:#8A6D00;\n}\n\n.today-header{\n    background:#E8F8EC;      /* Light Green */\n    color:#1B5E20;\n    border-top:1px solid #cfcfcf;\n}\n\n.inner-table{\n    width:100%;\n    border-collapse:collapse;\n    margin:0;\n    font-size:11px;\n}\n\n.inner-table th{\n    background:#F7F7F7;\n    text-align:center;\n}\n\n.inner-table td,\n.inner-table th{\n    border:1px solid #d8d8d8;\n    padding:5px;\n}\n</style>\n\n<div class=\"title\">\n    DYNATHERM ALLOYS PRIVATE LIMITED\n</div>\n\n<div class=\"subtitle\">\n    DAILY PURCHASE REPORT\n</div>\n\n<table class=\"info\">\n<tr>\n    <td><b>Date</b></td>\n    <td>{{ frappe.format(doc.date,\"Date\") }}</td>\n\n    <td><b>Department</b></td>\n    <td>{{ doc.department }}</td>\n</tr>\n\n</table>\n\n<div class=\"report-card\">\n\n    <div class=\"card-header yesterday-header\">\n        \ud83d\udccb YESTERDAY WORK\n    </div>\n\n    {% if doc.yesterday_po_report %}\n\n    {% set yesterday = frappe.get_doc(\"Daily PO Report\", doc.yesterday_po_report) %}\n\n    <table class=\"inner-table\">\n\n        <tr>\n    <th style=\"width:2%; text-align:center;\">S.No</th>\n    <th style=\"width:10%; text-align:center;\">Activity</th>\n    <th style=\"width:28%; text-align:center;\">Purchase Details</th>\n    <!--<th style=\"width:15%; text-align:center;\">Supplier</th>-->\n    <th style=\"width:37%; text-align:center;\">Item</th>\n    <th style=\"width:19%; text-align:center;\">Remarks</th>\n</tr>\n\n        {% for row in yesterday.items %}\n\n        <tr>\n\n    <td style=\"text-align:center; vertical-align:top;\"> {{ loop.index }} </td>\n\n    <td style=\"text-align:center; vertical-align:top;\"> {{ row.activity }} </td>\n\n\n    <td style=\"vertical-align:top; line-height:1.5;\">\n        <b>\n        {% if row.purchase_order_no %}\n            {{ row.purchase_order_no }}\n        {% else %}\n            -\n        {% endif %}</b>\n        <br>\n\n        <b> Project </b> : {{ row.job_no }} <br>\n        <b> Status </b> : {{ row.status or \"-\" }} <br>\n        <b> Supplier </b> : {{ row.supplier or \"-\" }}\n    </td>\n\n    <!--<td style=\"vertical-align:top;\"> {{ row.supplier or \"-\" }} </td>-->\n\n    <td style=\"vertical-align:top; line-height:1.5;\">\n        <b>Tag</b> : {{ row.tag_no or \"-\" }} <br>\n        <b>Details</b> : {{ row.item_details or \"-\" }} <br>\n        <b>Description</b> : {{ row.item_description or \"-\" }} </td>\n\n    <td style=\"vertical-align:top;\"> {{ row.remarks or \"-\" }} </td>\n</tr>\n\n        {% endfor %}\n\n    </table>\n\n    {% else %}\n\n    <div style=\"padding:12px;text-align:center;\"> No Yesterday Report Selected. </div>\n\n    {% endif %}\n    \n    <br>\n\n<div class=\"report-card\">\n\n    <div class=\"card-header today-header\"> \u2705 TODAY WORK\n  </div>\n\n    <table class=\"inner-table\">\n\n    <tr>\n    <th style=\"width:2%; text-align:center;\">S.No</th>\n    <th style=\"width:10%; text-align:center;\">Activity</th>\n    <th style=\"width:30%; text-align:center;\">Purchase Details</th>\n    <!--<th style=\"width:15%; text-align:center;\">Supplier</th>-->\n    <th style=\"width:39%; text-align:center;\">Item</th>\n    <th style=\"width:19%; text-align:center;\">Remarks</th>\n    </tr>\n\n        {% for row in doc.items %}\n\n       <tr>\n\n    <td style=\"text-align:center; vertical-align:top;\"> {{ loop.index }} </td>\n\n    <td style=\"text-align:center; vertical-align:top;\"> {{ row.activity }} </td>\n\n\n    <td style=\"vertical-align:top; line-height:1.5;\">\n        <b>\n        {% if row.purchase_order_no %}\n            {{ row.purchase_order_no }}\n        {% else %}\n            -\n        {% endif %}</b>\n        <br>\n\n        <b>Project</b> : {{ row.job_no }} <br>\n        <b>Status</b> : {{ row.status or \"-\" }} <br> \n        <b>Supplier</b> : {{ row.supplier or \"-\" }}\n    </td>\n\n    <!--<td style=\"vertical-align:top;\"> {{ row.supplier or \"-\" }} </td>-->\n\n    <td style=\"vertical-align:top; line-height:1.5;\">\n        <b>Tag</b> : {{ row.tag_no or \"-\" }} <br>\n        <b>Details</b> : {{ row.item_details or \"-\" }} <br>\n        <b>Description</b> : {{ row.item_description or \"-\" }} </td>\n\n    <td style=\"vertical-align:top;\"> {{ row.remarks or \"-\" }} </td>\n</tr>\n        {% endfor %}\n    </table>\n</div>\n<br><br>\n\n<table class=\"info\">\n<tr>\n\n<td style=\"text-align:center; width:50%;\">\n    <div><b>{{ doc.prepared_by }}</b></div>\n    <div style=\"width:150px; border-top:1px solid #000; margin:4px auto;\"></div>\n    <div>Prepared By</div>\n</td>\n\n<td style=\"text-align:center; width:50%;\">\n    <div><b>{{ doc.prepared_by }}</b></div>\n    <div style=\"width:150px; border-top:1px solid #000; margin:4px auto;\"></div>\n    <div>Purchase Manager</div>\n</td>\n\n</tr>\n\n</table>",
