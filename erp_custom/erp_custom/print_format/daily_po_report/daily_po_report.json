 "html": "<div class=\"page-outline\">\n\n    <!-- Header Section / Letterhead -->\n    <div class=\"letterhead-container\">\n        <div style=\"text-align:center; margin-bottom:10px;\">\n            {% if company_doc and company_doc.company_logo %}\n                <img src=\"{{ company_doc.company_logo }}\" style=\"max-height:55px;\"><br>\n            {% else %}\n                <img src=\"/files/DAPL_full_logo.png\" style=\"width:260px;margin-bottom:8px;\">\n            {% endif %}\n        </div>\n\n        <div style=\"text-align:center; font-size:11px; line-height:1.4; margin-bottom:10px;\">\n            <b>No.1, 1st Floor, 4th Cross Street, Devaraj Nagar, <br>\n            Sholinganallur, Chennai - 600119 </b> <br>\n            {% if company_doc and company_doc.gstin %}\n                <b>GSTIN :</b> {{ company_doc.gstin }}\n            {% endif %}\n        </div>\n    </div>\n\n    <!-- Title and Date in a single row -->\n    <table style=\"width: 100%; margin: 15px 0 5px 0; border-collapse: collapse;\">\n        <tr>\n            <td style=\"text-align: left; font-size: 15px; font-weight: bold; border: none; padding: 0;\">\n                DAILY PURCHASE REPORT\n            </td>\n            <td style=\"text-align: right; font-size: 11px; font-weight: bold; border: none; padding: 0;\">\n                Date: {{ frappe.format(doc.date, \"Date\") }}\n            </td>\n        </tr>\n    </table>\n\n    <!-- YESTERDAY WORK TABLE -->\n    <table class=\"report-table\">\n        <thead>\n            <tr>\n                <th colspan=\"5\" class=\"yesterday-header\"> \u2756 YESTERDAY WORK </th>\n            </tr>\n            {% if doc.yesterday_po_report %}\n            <tr>\n                <th style=\"width:2%;\">S.No</th>\n                <th style=\"width:8%;\">Activity</th>\n                <th style=\"width:30%;\">Purchase Details</th>\n                <th style=\"width:40%;\">Item</th>\n                <th style=\"width:20%;\">Remarks</th>\n            </tr>\n            {% endif %}\n        </thead>\n        <tbody>\n            {% if doc.yesterday_po_report %}\n                {% set yesterday = frappe.get_doc(\"Daily PO Report\", doc.yesterday_po_report) %}\n                {% for row in yesterday.items %}\n                <tr>\n                    <td style=\"text-align:center; vertical-align:top;\">{{ loop.index }}</td>\n                    <td style=\"text-align:center; vertical-align:top;\">{{ row.activity or \"-\" }}</td>\n                    <td style=\"vertical-align:top; line-height:1.4;\">\n                        <b>{{ row.purchase_order_no if row.purchase_order_no else \"-\" }}</b><br>\n                        <b>Project</b> : {{ row.job_no or \"-\" }}<br>\n                        <b>Status</b> : {{ row.status or \"-\" }}<br>\n                        <b>Supplier</b> : {{ row.supplier or \"-\" }}\n                    </td>\n                    <td style=\"vertical-align:top; line-height:1.4;\">\n                        <b>Tag</b> : {{ row.tag_no or \"-\" }}<br>\n                        <b>Details</b> : {{ row.item_details or \"-\" }}<br>\n                        <b>Description</b> : {{ row.item_description or \"-\" }}\n                    </td>\n                    <td style=\"vertical-align:top;\">{{ row.remarks or \"-\" }}</td>\n                </tr>\n                {% endfor %}\n            {% else %}\n                <tr>\n                    <td colspan=\"5\" style=\"text-align:center; padding:15px; font-size:12px; background:#fff;\">\n                        No Yesterday Report Selected.\n                    </td>\n                </tr>\n            {% endif %}\n        </tbody>\n    </table>\n\n    <!-- TODAY WORK TABLE -->\n    <table class=\"report-table\">\n        <thead>\n            <tr>\n                <th colspan=\"5\" class=\"today-header\"> \u2756 TODAY WORK </th>\n            </tr>\n            <tr>\n                <th style=\"width:2%;\">S.No</th>\n                <th style=\"width:8%;\">Activity</th>\n                <th style=\"width:30%;\">Purchase Details</th>\n                <th style=\"width:40%;\">Item</th>\n                <th style=\"width:20%;\">Remarks</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for row in doc.items %}\n            <tr>\n                <td style=\"text-align:center; vertical-align:top;\">{{ loop.index }}</td>\n                <td style=\"text-align:center; vertical-align:top;\">{{ row.activity or \"-\" }}</td>\n                <td style=\"vertical-align:top; line-height:1.4;\">\n                    <b>{{ row.purchase_order_no if row.purchase_order_no else \"-\" }}</b><br>\n                    <b>Project</b> : {{ row.job_no or \"-\" }}<br>\n                    <b>Status</b> : {{ row.status or \"-\" }}<br>\n                    <b>Supplier</b> : {{ row.supplier or \"-\" }}\n                </td>\n                <td style=\"vertical-align:top; line-height:1.4;\">\n                    <b>Tag</b> : {{ row.tag_no or \"-\" }}<br>\n                    <b>Details</b> : {{ row.item_details or \"-\" }}<br>\n                    <b>Description</b> : {{ row.item_description or \"-\" }}\n                </td>\n                <td style=\"vertical-align:top;\">{{ row.remarks or \"-\" }}</td>\n            </tr>\n            {% endfor %}\n        </tbody>\n    </table>\n\n    <!-- Signature / Footer Section (Bottom Right) -->\n    <div style=\"width: 100%; margin-top: 10px; text-align: right;\">\n        <div style=\"display: inline-block; text-align: center; min-width: 185px;\">\n            <div style=\"height: 30px;\"></div>\n            <div style=\"border-top: 1px solid #000; margin-bottom: 4px;\"></div>\n            <div style=\"font-size: 11px;\"><b>{{ doc.prepared_by or \"\" }}</b></div>\n            <div style=\"font-size: 11px;\">{{ doc.department or \"\" }}</div>\n        </div>\n    </div>\n\n</div>\n\n<style>\n/* Page setup to fit content on a single page and provide strict black borders per page */\n@page {\n    size: A4 portrait;\n    margin: 8mm;\n}\n\nbody {\n    margin: 0;\n    padding: 0;\n    background: #fff;\n    -webkit-print-color-adjust: exact;\n}\n\n.page-outline {\n    border: 1.5px solid #000000;\n    padding: 12px;\n    margin: 0 auto;\n    background: #fff;\n    box-sizing: border-box;\n    page-break-inside: avoid;\n    break-inside: avoid;\n}\n\n/* UNIFIED TABLE STYLE TO PREVENT DOUBLE BORDERS */\n.report-table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-top: 12px;\n    font-size: 10px;\n}\n\n.report-table th, \n.report-table td {\n    border: 1px solid #000000 !important; /* Forces uniform professional borders everywhere */\n    padding: 6px 8px;\n    vertical-align: top;\n}\n\n/* Main Headers (Yesterday / Today) */\n.yesterday-header {\n    background: #FFF6CC !important;\n    color: #8A6D00 !important;\n    text-align: left !important;\n    font-size: 12px;\n    font-weight: bold;\n    padding: 8px 10px !important;\n}\n\n.today-header {\n    background: #E7F7EB !important;\n    color: #166534 !important;\n    text-align: left !important;\n    font-size: 12px;\n    font-weight: bold;\n    padding: 8px 10px !important;\n}\n\n/* Sub Headers (S.No, Activity, etc.) */\n.report-table thead tr:nth-child(2) th {\n    background: #F3F4F6 !important;\n    color: #000 !important;\n    text-align: center;\n    font-weight: bold;\n}\n</style>",
