 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Workplan Print Format</title>\n    <style>\n        /* General Canvas Setup */\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n        \n        body {\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, Arial, sans-serif;\n            color: #000000; /* Absolute black text for clear contrast */\n            line-height: 1.5;\n            font-size: 11px;\n            margin: 0;\n            padding: 0;\n            background-color: #ffffff;\n            -webkit-print-color-adjust: exact;\n            print-color-adjust: exact;\n        }\n\n        .print-container {\n            max-width: 850px;\n            margin: 0 auto;\n            padding: 30px;\n        }\n\n        /* Executive Header Layout */\n        .header-wrapper {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-end;\n            border-bottom: 3px solid #000000; /* Dark prominent boundary line */\n            padding-bottom: 15px;\n            margin-bottom: 30px;\n        }\n        \n        .header-title-section h1 {\n            font-size: 26px;\n            font-weight: 700;\n            color: #000000;\n            margin: 0;\n            text-transform: uppercase;\n            letter-spacing: -0.5px;\n        }\n        \n        .header-title-section p {\n            margin: 4px 0 0 0;\n            font-size: 11px;\n            color: #334155; /* High contrast dark gray */\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            font-weight: 600;\n        }\n\n        .header-meta-card {\n            background-color: #f1f5f9;\n            border: 2px solid #0f172a; /* Sharp dark border */\n            border-radius: 6px;\n            padding: 8px 16px;\n            text-align: right;\n        }\n        \n        .header-meta-card .label {\n            font-size: 9px;\n            color: #334155;\n            font-weight: 700;\n            text-transform: uppercase;\n            display: block;\n        }\n        \n        .header-meta-card .value {\n            font-size: 14px;\n            color: #000000;\n            font-weight: 700;\n            margin-top: 2px;\n        }\n\n        /* High-Contrast Table Restructuring */\n        .workplan-table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-bottom: 40px;\n        }\n        \n        .workplan-table th {\n            background-color: #e2e8f0; /* Light background for columns */\n            color: #000000; /* Bold black text for headers */\n            font-weight: 700;\n            text-transform: uppercase;\n            font-size: 10px;\n            letter-spacing: 0.5px;\n            padding: 12px 10px;\n            text-align: left;\n            border-bottom: 3px solid #000000; /* Hard anchor line underneath */\n        }\n\n        .workplan-table td {\n            padding: 12px 10px;\n            border-bottom: 1px solid #94a3b8; /* Stronger horizontal separators */\n            vertical-align: top;\n            font-size: 11px;\n            color: #000000;\n        }\n        \n        /* Zebra-striping fallback for clean scanning */\n        .workplan-table tbody tr:nth-child(even) {\n            background-color: #f8fafc;\n        }\n\n        /* Data Fields Style Hierarchy */\n        .data-block {\n            margin-bottom: 10px;\n        }\n        .data-block:last-child {\n            margin-bottom: 0;\n        }\n\n        .field-lbl {\n            color: #475569; /* Clearly readable sub-labels */\n            font-size: 9px;\n            font-weight: 700;\n            text-transform: uppercase;\n            display: block;\n            margin-bottom: 2px;\n            letter-spacing: 0.3px;\n        }\n        \n        .field-val {\n            font-weight: 500;\n            color: #000000;\n        }\n        \n        .field-val.highlight {\n            font-weight: 700;\n            color: #000000;\n            font-size: 12px;\n        }\n\n        /* Standardized Badge Component */\n        .status-badge {\n            display: inline-block;\n            font-size: 10px;\n            font-weight: 700;\n            padding: 3px 8px;\n            border-radius: 4px;\n            text-transform: uppercase;\n            background-color: #bae6fd; /* Fallback default blue tint */\n            color: #0369a1;\n            border: 1px solid #0369a1;\n        }\n\n        /* [GREEN VARIANT] - Completed / Yes */\n        .status-badge.status-success {\n            background-color: #bbf7d0; \n            color: #15803d; \n            border: 1px solid #15803d;\n        }\n\n        /* [YELLOW VARIANT] - In Progress / No */\n        .status-badge.status-warning {\n            background-color: #fef08a; \n            color: #a16207; \n            border: 1px solid #a16207;\n        }\n\n        /* [LITE RED/ORANGE VARIANT] - Yet to Start */\n        .status-badge.status-danger {\n            background-color: #ffedd5; /* Clear, high-contrast amber/orange-red tint */\n            color: #c2410c; \n            border: 1px solid #c2410c;\n        }\n\n        /* Corporate Sign-off Footer Row */\n        .signature-container {\n            width: 100%;\n            border-collapse: separate;\n            border-spacing: 15px 0;\n            margin-top: 60px;\n            page-break-inside: avoid;\n        }\n        \n        .signature-card {\n            width: 25%;\n            background-color: #f1f5f9;\n            border: 1px solid #475569;\n            border-radius: 6px;\n            padding: 24px 12px 14px 12px;\n            text-align: center;\n            vertical-align: bottom;\n        }\n        \n        .sig-placeholder {\n            min-height: 35px;\n            font-size: 13px;\n            font-weight: 700;\n            color: #000000;\n            font-style: italic;\n            padding-bottom: 5px;\n        }\n        \n        .sig-line {\n            border-top: 2px solid #000000; /* Solid line for signatures */\n            margin-bottom: 8px;\n        }\n        \n        .sig-title {\n            font-size: 10px;\n            font-weight: 700;\n            color: #000000;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        /* Print Engine Enhancements */\n        @media print {\n            body { \n                background: #ffffff; \n            }\n            .print-container { \n                padding: 0; \n                max-width: 100%; \n            }\n            .workplan-table tr { \n                page-break-inside: avoid !important; \n            }\n            .signature-container { \n                page-break-inside: avoid !important; \n            }\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"print-container\">\n\n    <div class=\"header-wrapper\">\n        <div class=\"header-title-section\">\n            <h1>Daily Workplan</h1>\n            <p>Operational Performance Sheet</p>\n        </div>\n        <div class=\"header-meta-card\">\n            <span class=\"label\">Execution Date</span>\n            <div class=\"value\">{{ doc.get_formatted('date') if doc.date else '' }}</div>\n        </div>\n    </div>\n\n    <table class=\"workplan-table\">\n        <thead>\n            <tr>\n                <th style=\"width: 20%;\">Assignment</th>\n                <th style=\"width: 15%;\">Trackers</th>\n                <th style=\"width: 18%;\">Status Metrics</th>\n                <th style=\"width: 14%;\">Timeline</th>\n                <th style=\"width: 13%; text-align: center;\">QC Check</th>\n                <th style=\"width: 20%;\">Directives & Notes</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% if doc.table_cfdd %}\n                {% for item in doc.table_cfdd %}\n                {# Clean-filter out completely blank initialized rows #}\n                {% if item.department or item.job_no or item.work or item.name1 %}\n                <tr>\n                    <td>\n                        <div class=\"data-block\">\n                            <span class=\"field-lbl\">Department</span>\n                            <span class=\"field-val highlight\">{{ item.department or '-' }}</span>\n                        </div>\n                        <div class=\"data-block\">\n                            <span class=\"field-lbl\">Personnel</span>\n                            <span class=\"field-val\">{{ item.name1 or '-' }}</span>\n                        </div>\n                    </td>\n                    \n                    <td>\n                        <div class=\"data-block\">\n                            <span class=\"field-lbl\">Job Number</span>\n                            <span class=\"field-val highlight\">{{ item.job_no or '-' }}</span>\n                        </div>\n                        <div class=\"data-block\">\n                            <span class=\"field-lbl\">Tag Assignment</span>\n                            <span class=\"field-val\">{{ item.tag_no or '-' }}</span>\n                        </div>\n                    </td>\n                    \n                    <td>\n                        <div class=\"data-block\">\n                            <span class=\"field-lbl\">Attendance</span>\n                            <span class=\"field-val\" style=\"font-weight: 600;\">{{ item.attendance_status or '-' }}</span>\n                        </div>\n                        <div class=\"data-block\" style=\"margin-top: 5px;\">\n                            <span class=\"field-lbl\">Completion</span>\n                            {# Dynamic Completion Status Coloring Rule #}\n                            {% if item.completion_status == 'Completed' %}\n                                <span class=\"status-badge status-success\">{{ item.completion_status }}</span>\n                            {% elif item.completion_status == 'In Progress' %}\n                                <span class=\"status-badge status-warning\">{{ item.completion_status }}</span>\n                            {% elif item.completion_status == 'Yet to Start' %}\n                                <span class=\"status-badge status-danger\">{{ item.completion_status }}</span>\n                            {% else %}\n                                <span class=\"status-badge\">{{ item.completion_status or '-' }}</span>\n                            {% endif %}\n                        </div>\n                    </td>\n                    \n                    <td>\n                        <div class=\"data-block\">\n                            <span class=\"field-lbl\">Check In</span>\n                            <span class=\"field-val\">{{ item.in_time or '-' }}</span>\n                        </div>\n                        <div class=\"data-block\">\n                            <span class=\"field-lbl\">Check Out</span>\n                            <span class=\"field-val\">{{ item.out_time or '-' }}</span>\n                        </div>\n                    </td>\n                    \n                    <td style=\"text-align: center; vertical-align: middle;\">\n                        {# Dynamic QC Clearance Code Segment #}\n                        {% if item.qc_clearance == 'Yes' %}\n                            <span class=\"status-badge status-success\" style=\"padding: 4px 12px;\">Yes</span>\n                        {% elif item.qc_clearance == 'No' %}\n                            <span class=\"status-badge status-warning\" style=\"padding: 4px 12px;\">No</span>\n                        {% else %}\n                            <span style=\"color: #64748b; font-weight: bold;\">{{ item.qc_clearance or '-' }}</span>\n                        {% endif %}\n                    </td>\n                    \n                    <td>\n                        <div class=\"data-block\">\n                            <span class=\"field-lbl\">Work Assignment</span>\n                            <div style=\"font-weight: 600; white-space: pre-line; margin-bottom: 6px;\">{{ item.work or '-' }}</div>\n                        </div>\n                        {% if item.remarks %}\n                        <div class=\"data-block\">\n                            <span class=\"field-lbl\">Remarks</span>\n                            <div style=\"font-style: italic; font-weight: 500; white-space: pre-line;\">{{ item.remarks }}</div>\n                        </div>\n                        {% endif %}\n                    </td>\n                </tr>\n                {% endif %}\n                {% endfor %}\n            {% else %}\n                <tr>\n                    <td colspan=\"6\" style=\"text-align: center; color: #000000; padding: 30px; font-weight: 700;\">\n                        No active workplan items indexed for this date parameter.\n                    </td>\n                </tr>\n            {% endif %}\n        </tbody>\n    </table>\n\n    <table class=\"signature-container\">\n        <tr>\n            <td class=\"signature-card\">\n                <div class=\"sig-placeholder\">{{ doc.prepared_by or '' }}</div>\n                <div class=\"sig-line\"></div>\n                <div class=\"sig-title\">Prepared By</div>\n            </td>\n            \n            <td class=\"signature-card\">\n                <div class=\"sig-placeholder\">{{ doc.shop_floor_supervisor or '' }}</div>\n                <div class=\"sig-line\"></div>\n                <div class=\"sig-title\">Shop Floor Supervisor</div>\n            </td>\n\n            <td class=\"signature-card\">\n                <div class=\"sig-placeholder\">{{ doc.machine_supervisor or '' }}</div>\n                <div class=\"sig-line\"></div>\n                <div class=\"sig-title\">Machine Supervisor</div>\n            </td>\n\n            <td class=\"signature-card\">\n                <div class=\"sig-placeholder\">{{ doc.factory_manager or '' }}</div>\n                <div class=\"sig-line\"></div>\n                <div class=\"sig-title\">Factory Manager</div>\n            </td>\n        </tr>\n    </table>\n\n</div>\n\n</body>\n</html>",
